# =============================================================================
# LCI Social Desk — environment template
# =============================================================================
# Copy this file to `.env.local` for local development:
#
#     cp .env.example .env.local
#
# `.env.local` is git-ignored. For production, set these in
# Vercel → Project Settings → Environment Variables (not in this file).
#
# Two security tiers:
#   * NEXT_PUBLIC_* values are bundled into the client JS by Next.js. They
#     are identifiers, not secrets. Safe to expose. Security comes from the
#     Firebase Console authorized-domains list and your Firestore rules.
#   * Everything else is server-only and MUST stay secret.
# =============================================================================


# -----------------------------------------------------------------------------
# Session + token signing (server-only secrets)
# -----------------------------------------------------------------------------
# Generate with:  openssl rand -hex 32
SESSION_SECRET=
# Optional — falls back to SESSION_SECRET if unset.
INVITE_TOKEN_SECRET=
# Optional — falls back to INVITE_TOKEN_SECRET / SESSION_SECRET if unset.
REVIEW_TOKEN_SECRET=
# Optional — falls back to SESSION_SECRET if unset.
META_STATE_SECRET=


# -----------------------------------------------------------------------------
# Public app URL (used to build invite links: NEXT_PUBLIC_APP_URL/connect/...)
# -----------------------------------------------------------------------------
# Local dev:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production example (configure in Vercel):
# NEXT_PUBLIC_APP_URL=https://lci-social-desk.vercel.app


# -----------------------------------------------------------------------------
# Firebase Authentication — CLIENT config (public by design)
# -----------------------------------------------------------------------------
# Get these from Firebase Console → Project Settings → Your apps → Web app.
# These end up in the browser bundle; that is expected. Lock down access in
# Firebase Console → Authentication → Settings → Authorized domains.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abc123
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000


# -----------------------------------------------------------------------------
# Firebase Admin SDK — SERVER config (REAL SECRETS — never commit, never expose)
# -----------------------------------------------------------------------------
# Generate a service account in Firebase Console → Project Settings →
# Service accounts → Generate new private key. You'll download a JSON file.
# Take three values out of it:
#   project_id    -> FIREBASE_PROJECT_ID
#   client_email  -> FIREBASE_CLIENT_EMAIL
#   private_key   -> FIREBASE_PRIVATE_KEY
#
# The private key contains literal newlines. When pasted into a .env file
# or Vercel UI, keep the surrounding quotes and the \n escape sequences as
# they appear in the JSON — the app un-escapes them at runtime.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...REPLACE_ME...==\n-----END PRIVATE KEY-----\n"


# -----------------------------------------------------------------------------
# Role bootstrap (until agencyMembers is wired to Firestore)
# -----------------------------------------------------------------------------
# Comma-separated emails. Anyone signing in whose email matches AGENCY_OWNERS
# is granted "owner"; AGENCY_ADMINS → "admin"; everyone else defaults to
# "member".
AGENCY_OWNERS=you@youragency.com,partner@youragency.com
AGENCY_ADMINS=


# -----------------------------------------------------------------------------
# Meta (Facebook + Instagram) OAuth — SERVER secrets
# -----------------------------------------------------------------------------
# Get these from developers.facebook.com → My Apps → <your app> →
# Settings → Basic. Use a long-lived business app, not a personal one.
META_APP_ID=
META_APP_SECRET=
# Where Meta sends the user back. Must match exactly in the Meta App settings.
META_REDIRECT_URI=http://localhost:3000/api/oauth/meta/callback
# Sensible default scopes; override only if you've cleared a different set
# through Meta App Review.
META_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts,instagram_basic,instagram_content_publish,business_management


# -----------------------------------------------------------------------------
# Cron job secret (Vercel Cron Jobs)
# -----------------------------------------------------------------------------
# Vercel automatically sends this in the Authorization header when invoking
# /api/cron/publish-scheduled. Generate with:  openssl rand -hex 32
# Set this in Vercel → Project Settings → Environment Variables.
# NOTE: Vercel Hobby plan runs crons at most once per hour (0 * * * *).
#       Vercel Pro plan supports per-minute crons (* * * * *).
CRON_SECRET=


# -----------------------------------------------------------------------------
# Optional toggles
# -----------------------------------------------------------------------------
# "firebase" forces real auth (hides demo button even if Firebase config is
# incomplete). "demo" forces the demo path on. Unset = auto-detect.
NEXT_PUBLIC_AUTH_MODE=firebase
# Shown on /connect/[token] when a client needs help.
NEXT_PUBLIC_SUPPORT_EMAIL=hello@lci.agency


# -----------------------------------------------------------------------------
# Resend (transactional email — invite + review request emails)
# -----------------------------------------------------------------------------
# Required to actually email invite and review links to clients. Without
# RESEND_API_KEY the dashboard still generates copyable links, but the
# "Send invite" / "Send email" buttons are hidden and the API returns 503.
RESEND_API_KEY=
# Verified sender. Format: "Display Name <you@your-domain.com>". Defaults to
# "LCI Social Desk <noreply@resend.dev>" for sandbox testing, but you'll
# need to verify your own domain in Resend for production deliverability.
EMAIL_FROM=
# Public-facing agency name used in invite + review email copy.
NEXT_PUBLIC_AGENCY_NAME=LCI

# Optional: send via a Resend-hosted template (designed in the Resend
# dashboard) instead of the built-in HTML. Accepts the template's UUID or
# its alias. The template MUST be published — drafts are rejected.
#
# Variables your template can reference with {{NAME}}:
#   Review email:  CUSTOMER_NAME, CLIENT_NAME, AGENCY_NAME, NETWORKS,
#                  REVIEW_URL, CAPTION, SCHEDULE_DATE, SCHEDULE_TIME,
#                  SCHEDULE_LINE
#   Invite email:  CUSTOMER_NAME, CLIENT_NAME, AGENCY_NAME, NETWORKS,
#                  INVITE_URL
#
# Hit GET /api/dev/email-preview/{invite|review} during local dev to see
# the exact variable payload that will be sent.
RESEND_REVIEW_TEMPLATE_ID=
RESEND_INVITE_TEMPLATE_ID=
